# ============================================
# Mailbot Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- Email Account ---
# Your email address
EMAIL_USER=you@example.com
# App Password (NOT your regular password)
# Gmail: https://myaccount.google.com/apppasswords
# Outlook: https://account.live.com/proofs/AppPassword
EMAIL_PASS=your_app_password_here

# --- IMAP (reading emails) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# --- SMTP (sending emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- API Server ---
API_PORT=3100

# --- Safety ---
# When true, emails are NOT actually sent (logged only)
# Set to false only when you're ready to send for real
DRY_RUN=true

# --- Notifications (optional) ---
# Webhook URL to notify when new emails arrive (used by cron.js)
# WEBHOOK_URL=https://your-webhook-url.com/notify
